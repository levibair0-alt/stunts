# Athena Orchestrator Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# OpenAI / GPT
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google / Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# xAI / Grok
XAI_API_KEY=xai-your-xai-api-key-here

# NotebookLM (if applicable)
NOTEBOOKLM_API_KEY=your-notebooklm-api-key-here

# =============================================================================
# GitHub Integration
# =============================================================================

GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_USERNAME=your-github-username

# =============================================================================
# Notion Integration
# =============================================================================

NOTION_API_KEY=secret_your-notion-integration-token
NOTION_VERSION=2022-06-28

# Notion Database IDs (optional - can be configured via UI)
# NOTION_MASTER_PROJECTS_DB=your-master-projects-db-id
# NOTION_MASTER_RUNS_DB=your-master-runs-db-id
# NOTION_PROJECT_TASKS_DB=your-project-tasks-db-id
# NOTION_PROJECT_RUNS_DB=your-project-runs-db-id
# NOTION_PROJECT_DOCS_DB=your-project-docs-db-id

# =============================================================================
# CTO.new Integration
# =============================================================================

CTO_API_KEY=your-cto-api-key-here
CTO_BASE_URL=https://api.cto.new

# =============================================================================
# Sentry Error Tracking (Optional)
# =============================================================================

SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# =============================================================================
# Voice Control (Optional)
# =============================================================================

# WebSocket configuration
VOICE_WEBSOCKET_HOST=localhost
VOICE_WEBSOCKET_PORT=8766

# Whisper model size (tiny, base, small, medium, large)
WHISPER_MODEL_SIZE=base

# Wake word sensitivity (0.0 - 1.0)
WAKE_WORD_SENSITIVITY=0.8

# =============================================================================
# Pipeline Configuration
# =============================================================================

# Default LLM provider (openai, anthropic, gemini, grok)
DEFAULT_LLM_PROVIDER=openai

# Default pipeline mode (sync, async)
DEFAULT_PIPELINE_MODE=async

# Max concurrent tasks
MAX_CONCURRENT_TASKS=5

# =============================================================================
# Development Settings
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable debug mode
DEBUG=false

# Enable dry run mode (no actual API calls)
DRY_RUN=false
